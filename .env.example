APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Replace with your actual domain in production.
PUBLIC_BASE_URL=https://xxxx.example.ru

# GigaChat settings
# See token flow docs:
# https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post-token
GIGACHAT_AUTH_KEY=replace_me
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_TOKEN_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
GIGACHAT_VERIFY_SSL=false
GIGACHAT_MODEL=GigaChat

# Bitrix24 settings
BITRIX_WEBHOOK_URL=https://b24-i0ij9o.bitrix24.ru/rest/1/xp2q51ovb3xzytdl/
DEFAULT_MANAGER_ID=1

# Working hours and SLA
DEALER_WORKING_HOURS=09:00-21:00
MANAGER_RESPONSE_SLA_MINUTES=15

# RAG/ChromaDB
CHROMA_PATH=data/chroma
CHROMA_COLLECTION_NAME=autosales_faq
